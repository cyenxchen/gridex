<Page
    x:Class="Gridex.MCPPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Gridex"
    Background="Transparent">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: back button + title + server status pill + Start/Stop -->
        <Grid Grid.Row="0" Padding="24,16,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackBtn" Grid.Column="0"
                    Background="Transparent" BorderThickness="0"
                    Padding="8,4" VerticalAlignment="Center"
                    ToolTipService.ToolTip="Back"
                    Click="Back_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="Back" FontSize="13" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center" Margin="16,0,0,0">
                <!-- Status dot — gray (off) / green (running) / orange (pending). -->
                <Ellipse x:Name="StatusDot" Width="10" Height="10"
                         Fill="Gray" />
                <StackPanel>
                    <TextBlock Text="MCP Server" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText"
                               Text="Stopped"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <Button x:Name="StartStopBtn" Grid.Column="3"
                    Padding="16,6"
                    Content="Start Server"
                    Click="StartStop_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <!-- Pivot = 5 tabs matching mac. Each tab body is its own
             panel — Overview is wired fully, the rest show a
             placeholder until the implementation catches up. -->
        <Pivot Grid.Row="1" x:Name="Tabs" Margin="16,0,16,16">
            <PivotItem Header="Overview">
                <ScrollViewer>
                    <StackPanel Spacing="20" MaxWidth="820" HorizontalAlignment="Stretch">

                        <!-- Running card -->
                        <Border Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon x:Name="RunningIcon" Glyph="&#xE711;"
                                          FontSize="22"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <StackPanel>
                                    <TextBlock x:Name="RunningTitle"
                                               Text="MCP Server is stopped"
                                               FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="RunningSubtitle"
                                               Text="Enable below to let AI clients connect."
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Access summary (per-mode connection counts) -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Access" FontSize="14" FontWeight="SemiBold" />
                            <Border Padding="16" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Locked" Grid.Column="0" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="Red" />
                                            <TextBlock x:Name="LockedCount" Text="0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Read-only" Grid.Column="0" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="DodgerBlue" />
                                            <TextBlock x:Name="ReadOnlyCount" Text="0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Read-write" Grid.Column="0" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" Fill="SeaGreen" />
                                            <TextBlock x:Name="ReadWriteCount" Text="0" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Transport -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Transport" FontSize="14" FontWeight="SemiBold" />
                            <Border Padding="16" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="stdio" Grid.Column="0" />
                                        <TextBlock Text="Local clients ✓"
                                                   Grid.Column="1"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="HTTP" Grid.Column="0" />
                                        <ToggleSwitch x:Name="HttpToggle"
                                                      Grid.Column="1"
                                                      Toggled="HttpToggle_Toggled"
                                                      OffContent="" OnContent="" />
                                    </Grid>
                                    <Grid x:Name="HttpPortRow" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Port" Grid.Column="0" />
                                        <NumberBox x:Name="HttpPortBox"
                                                   Grid.Column="1"
                                                   Minimum="1024" Maximum="65535"
                                                   Value="3333" Width="120" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Tool inventory -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Tools registered"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ToolsCountText"
                                       Text="0 tools"
                                       FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem Header="Connections">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE968;" FontSize="36"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Per-connection access mode"
                               HorizontalAlignment="Center" FontSize="14" />
                    <TextBlock Text="Set per-connection Locked / Read-only / Read-write in the Connection Settings dialog for now. This full table view is coming next."
                               HorizontalAlignment="Center" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MaxWidth="520" TextAlignment="Center" />
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Activity">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE9D9;" FontSize="36"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Audit log viewer coming next"
                               HorizontalAlignment="Center" FontSize="14" />
                    <TextBlock x:Name="ActivityPathText"
                               HorizontalAlignment="Center" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               IsTextSelectionEnabled="True" />
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Setup">
                <ScrollViewer>
                    <StackPanel Spacing="16" MaxWidth="820">
                        <TextBlock Text="Paste this JSON into your Claude Desktop config file"
                                   FontSize="14" FontWeight="SemiBold" />
                        <TextBlock x:Name="SetupPathText"
                                   FontSize="12"
                                   IsTextSelectionEnabled="True"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border Padding="12" CornerRadius="6"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <TextBox x:Name="SetupConfigBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     MinHeight="160" />
                        </Border>
                        <Button x:Name="CopyConfigBtn"
                                Content="Copy Config"
                                Click="CopyConfig_Click"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <PivotItem Header="Config">
                <ScrollViewer>
                    <StackPanel Spacing="16" MaxWidth="820">
                        <TextBlock Text="Rate Limits" FontSize="14" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="16" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Queries per minute" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="QpmBox" Grid.Row="0" Grid.Column="1"
                                       Minimum="10" Maximum="500" Value="60" />
                            <TextBlock Text="Queries per hour" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="QphBox" Grid.Row="1" Grid.Column="1"
                                       Minimum="100" Maximum="10000" Value="1000" />
                            <TextBlock Text="Writes per minute" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="WpmBox" Grid.Row="2" Grid.Column="1"
                                       Minimum="1" Maximum="100" Value="10" />
                            <TextBlock Text="DDL per minute" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="DdlBox" Grid.Row="3" Grid.Column="1"
                                       Minimum="1" Maximum="20" Value="1" />
                        </Grid>

                        <TextBlock Text="Audit Log" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <Grid ColumnSpacing="16" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Retention (days)" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="RetentionBox" Grid.Row="0" Grid.Column="1"
                                       Minimum="0" Maximum="3650" Value="90" />
                            <TextBlock Text="Max log size (MB)" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                            <NumberBox x:Name="MaxSizeBox" Grid.Row="1" Grid.Column="1"
                                       Minimum="10" Maximum="1000" Value="100" />
                        </Grid>

                        <Button x:Name="SaveConfigBtn"
                                Content="Save Config"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Click="SaveConfig_Click" />
                        <TextBlock x:Name="SaveConfigStatusText"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
